# =============================================================================
# Intent Tracker — Single .env for the entire monorepo
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Runtime environment (dev | staging | production) ------------------------
# In staging/production SCAN_TOKEN must be set and ALLOWED_ORIGINS must be a
# non-empty comma-separated list, otherwise CORS fails closed.
ENVIRONMENT=dev

# --- CORS (comma-separated origins, empty = dev defaults of localhost:WEB_PORT)
ALLOWED_ORIGINS=

# --- Shared secret for POST /api/scan (required outside dev) -----------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SCAN_TOKEN=

# --- Reddit API (free — register at https://www.reddit.com/prefs/apps) --------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=IntentTracker/1.0

# --- GitHub Personal Access Token ---------------------------------------------
# Optional — raises rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (scope: public_repo read-only)
GITHUB_TOKEN=

# --- Dune Analytics -----------------------------------------------------------
# Optional — free tier: 2500 credits/month
# Get key at https://dune.com/settings/api
DUNE_API_KEY=

# --- Server ports -------------------------------------------------------------
API_PORT=8000
WEB_PORT=3000

# --- Scheduler (cron format) --------------------------------------------------
SCAN_DAY=mon
SCAN_HOUR=6
SCAN_MINUTE=0

# --- Web (Next.js) — NEXT_PUBLIC_* is exposed to the browser ------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Database -----------------------------------------------------------------
# Override only if you want the DB somewhere other than <repo>/data/intent_tracker.db
# DB_PATH=

